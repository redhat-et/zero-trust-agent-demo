# AWS credentials for the credential gateway.
#
# Before deploying, replace the placeholder values below with your actual
# AWS credentials and role ARN, or create the secret manually:
#
#   oc create secret generic credential-gateway-aws \
#     --namespace=spiffe-demo \
#     --from-literal=SPIFFE_DEMO_AWS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/zt-demo-delegated-access \
#     --from-literal=SPIFFE_DEMO_AWS_S3_BUCKET=zt-demo-documents \
#     --from-literal=SPIFFE_DEMO_AWS_REGION=us-east-1 \
#     --from-literal=AWS_ACCESS_KEY_ID=... \
#     --from-literal=AWS_SECRET_ACCESS_KEY=...
#
apiVersion: v1
kind: Secret
metadata:
  name: credential-gateway-aws
  namespace: spiffe-demo
type: Opaque
stringData:
  SPIFFE_DEMO_AWS_ROLE_ARN: "arn:aws:iam::123456789012:role/zt-demo-delegated-access"
  SPIFFE_DEMO_AWS_S3_BUCKET: "zt-demo-documents"
  SPIFFE_DEMO_AWS_REGION: "us-east-1"
  AWS_ACCESS_KEY_ID: "CHANGE_ME"
  AWS_SECRET_ACCESS_KEY: "CHANGE_ME"
